# Base path for deployment (e.g., /import for subpath deployment)
# Leave empty for root path deployment
BASE_PATH=

# Port for backend server (default: 7395)
PORT=7395

# Path to the cook executable or mock script
# For development: cook-toy (mock script)
# For production: /opt/cook-import-server/cookcli/target/release/cook
COOK_PATH=cook-toy

# Directory where imported recipes will be saved
# For development: ../recipes/import (relative path)
# For production: /opt/cook-import-server/recipes/import (absolute path)
RECIPES_DIR=../recipes/import
