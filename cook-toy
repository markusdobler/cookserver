#!/usr/bin/env python3
"""
Mock cook tool for testing recipe imports.
Generates recipe content with dynamic titles extracted from URLs.
"""

import sys
import re
from urllib.parse import urlparse


def extract_title_from_url(url: str) -> str:
    """Extract a title from the URL"""
    # Try to get fragment (after #)
    if '#' in url:
        fragment = url.split('#')[-1]
        # Convert hyphens/underscores to spaces and title case
        title = fragment.replace('-', ' ').replace('_', ' ').title()
        if title:
            return title
    
    # Try to get last path segment
    parsed = urlparse(url)
    path = parsed.path.rstrip('/')
    if path:
        last_segment = path.split('/')[-1]
        # Remove file extension if present
        last_segment = re.sub(r'\.[^.]+$', '', last_segment)
        # Convert hyphens/underscores to spaces and title case
        title = last_segment.replace('-', ' ').replace('_', ' ').title()
        if title:
            return title
    
    # Fallback to domain name
    domain = parsed.netloc or parsed.path.split('/')[0]
    return domain.replace('.', ' ').title() + " Recipe"


def generate_recipe(url: str) -> str:
    """Generate a mock recipe with frontmatter"""
    title = extract_title_from_url(url)
    
    recipe = f"""---
title: {title}
source: {url}
tags: [imported, test]
---

# {title}

This is a mock recipe imported from {url}.

## Ingredients

- 2 cups flour
- 1 cup sugar
- 3 eggs
- 1 tsp vanilla extract

## Instructions

1. Preheat oven to 350°F (175°C)
2. Mix dry ingredients
3. Add wet ingredients
4. Bake for 30 minutes
5. Let cool and serve

Enjoy your {title}!
"""
    return recipe


def main():
    if len(sys.argv) < 3:
        print("Usage: cook-toy import <url>", file=sys.stderr)
        sys.exit(1)
    
    command = sys.argv[1]
    
    if command != "import":
        print(f"Unknown command: {command}", file=sys.stderr)
        sys.exit(1)
    
    url = sys.argv[2]
    recipe = generate_recipe(url)
    print(recipe)


if __name__ == "__main__":
    main()
